---
import ProjectsAPI from "@/API/ProjectsAPI";
import Layout from "@/layouts/Layout.astro";
import ProjectItem from "@/components/projects/ProjectItem.astro";
import type { BreadcrumbItem } from "@/types";
import { ProjectsWithPagination } from "@/schemas/projects";

const search = Astro.url.searchParams.get("search") || "";
const page = Number(Astro.url.searchParams.get("page") || "1");

const response = await ProjectsAPI.getProjects({
    page,
    search,
});

const projects = ProjectsWithPagination.parse(response);

const breadcrumbs: BreadcrumbItem[] = [
    {
        title: "Inicio",
        href: "/",
    },
    {
        title: "Proyectos",
        href: "/projects",
    },
];
---

<Layout
    withSearch
    breadcrumbs={breadcrumbs}
    title="Blog"
    description="Proyectos creados por estudiantes y por la comunidad."
>
    <div class="mx-auto max-w-6xl px-4 py-12 md:px-6 lg:px-8">
        <h1
            class="text-3xl font-bold tracking-tight text-foreground md:text-4xl"
        >
            Proyectos
        </h1>

        <p class="mt-2 text-base text-muted-foreground">
            Proyectos creados por estudiantes y por la comunidad.
        </p>

        {
            projects.data.length === 0 ? (
                <p class="text-center text-muted-foreground py-20">
                    No hay artículos publicados aún.
                </p>
            ) : (
                <div
                    class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3 mt-10"
                    role="list"
                >
                    {projects.data.map((project) => (
                        <ProjectItem project={project} />
                    ))}
                </div>
            )
        }
    </div>
</Layout>
