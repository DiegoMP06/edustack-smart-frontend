---
import Layout from "@/layouts/Layout.astro";
---

<Layout title="Algo salió mal, inténtalo mas tarde" noindex>
    <div
        class="flex flex-col items-center justify-center gap-10 px-4 text-center my-20"
    >
        <div
            class="text-8xl font-black text-indigo-100 dark:text-indigo-900 select-none"
        >
            500
        </div>
        <div>
            <h1 class="text-2xl font-bold text-foreground mb-2">
                Algo salió mal
            </h1>
            <p class="text-slate-500">
                Lo sentimos, ha ocurrido un error inesperado. Por favor,
                inténtalo de nuevo más tarde.
            </p>
        </div>
        <a
            href="/"
            class="rounded-xl bg-indigo-600 px-6 py-3 text-sm font-semibold text-white hover:bg-indigo-700 transition-colors"
        >
            Volver al inicio
        </a>
    </div>
</Layout>
