---
import { formatDate } from "@/lib/utils/date";
import { getIdealResponsiveMediaLink } from "@/lib/utils/media";
import {
    Item,
    ItemContent,
    ItemDescription,
    ItemHeader,
    ItemTitle,
    ItemFooter,
} from "@/components/ui/shadcn/item";
import type {Project} from '@/types'
import { Picture } from "astro:assets";
import { Badge } from "@/components/ui/shadcn/badge";
import Icon from '@/components/ui/app/Icon'

type Props = {
    project: Project;
}

const {project} = Astro.props

const MAX_TECHS = 5

const visibleTechs = project.tech_stack.slice(0, MAX_TECHS);
const overflowTechs = project.tech_stack.length - MAX_TECHS;
---

<Item variant="outline" className="p-0 overflow-hidden" role="listitem">
    <ItemHeader className="aspect-video overflow-hidden">
        <a
            href={`/projects/${project.slug}`}
            tabindex="-1"
            aria-hidden="true"
            class="block w-full h-full"
        >
            <Picture
                src={getIdealResponsiveMediaLink(project.media?.[0])}
                alt={`Imagen de portada: ${project.name}`}
                width={project.media?.[0].dimensions.main.width}
                height={project.media?.[0].dimensions.main.height}
                loading="lazy"
                decoding="async"
                class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
                formats={["avif", "webp", "jpeg"]}
            />
        </a>
    </ItemHeader>

    <ItemContent className="p-4">
        <div class="flex items-center gap-2 mb-2 justify-between">
            <p
                class="flex items-center gap-1 text-xs font-medium px-2.5 py-0.5 rounded-xl"
                style={{
                    border: `1px solid ${project.status.color ?? '#6366f1'}`,
                    color: `${project.status.color ?? '#6366f1'}`,
                }}
            >
                {project.status.name}
            </p>

            <time
                datetime={project.published_at}
                class="text-xs text-muted-foreground"
            >
                {formatDate(project.published_at)}
            </time>
        </div>

        <ItemTitle className="flex-col items-start mt-2 gap-0">
            <h2>
                <a href={`/projects/${project.slug}`}>
                    {project.name}
                </a>
            </h2>

            <p class="text-xs text-muted-foreground">
                v{project.version} · {project.license}
            </p>
        </ItemTitle>

        <ItemDescription className="mt-4">{project.description}</ItemDescription>
        
        <div class="flex gap-2 flex-wrap mt-2">
            {visibleTechs.map((tech) => (
                <Badge variant="secondary">{tech}</Badge>
            ))}

            {overflowTechs > 0 && (
                <Badge variant="outline">
                    +{overflowTechs}
                </Badge>
            )}
        </div>

        <ItemFooter className="mt-4">
            <p class="text-xs">
                {project.author.name}
                {project.author.father_last_name}
                {project.author.mother_last_name}
            </p>

            <nav class="flex items-center gap-2">
                <a 
                    title="Ir al repositorio" 
                    href={project.repository_url} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="p-2 rounded-md bg-primary text-primary-foreground cursor-pointer block "
                >
                    <Icon iconName="git-branch" className="size-4" />
                </a>
                
                <a 
                    title="Ir al demo" 
                    href={project.demo_url} 
                    target="_blank" 
                    rel="noopener noreferrer"
                    class="p-2 rounded-md bg-secondary text-secondary-foreground cursor-pointer block "
                >
                    <Icon iconName="link-2" className="size-4" />
                </a>
            </nav>
        </ItemFooter>
    </ItemContent>
</Item>
