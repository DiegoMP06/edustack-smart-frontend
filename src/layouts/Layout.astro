---
import "../styles/global.css";

import { ClientRouter } from "astro:transitions";
import Header from "@/components/ui/app/Header.astro";
import Footer from "@/components/ui/app/Footer.astro";
import BreadcrumbNav from "@/components/ui/app/BreadcrumbNav.astro";
import type { BreadcrumbItem } from "@/types";

export interface Props {
    withSearch?: boolean;
    breadcrumbs?: BreadcrumbItem[];
    title?: string;
    description?: string;
    image?: string;
    canonical?: string;
    noindex?: boolean;
    jsonLd?: Record<string, unknown>;
    aiContext?: {
        type: string;
        title: string;
        summary?: string;
        plainText?: string;
    };
}

const {
    withSearch = false,
    breadcrumbs = [],
    title,
    description,
    image,
    canonical = Astro.url.toString(),
    noindex = false,
    jsonLd,
    aiContext,
} = Astro.props;

const r2Domain = import.meta.env.R2_DOMAIN?.replace(/'/g, "");
const r2Url = `https://${r2Domain}`;

const appearance = Astro.cookies.get("theme")?.value ?? "system";
const fullTitle = `EduStack Smart | ${title}`;
const siteUrl = import.meta.env.SITE_URL ?? "http://localhost:4321";
const ogImage = image
    ? image.startsWith("http")
        ? image
        : `${siteUrl}${image}`
    : `${siteUrl}/og-default.png`;
---

<!doctype html>
<html lang="es" class={appearance === "dark" ? "dark" : ""}>
    <head>
        <script is:inline define:vars={{ appearance }}>
            const applyTheme = () => {
                let themeToApply = appearance;

                if (themeToApply === "system") {
                    themeToApply = window.matchMedia(
                        "(prefers-color-scheme: dark)",
                    ).matches
                        ? "dark"
                        : "light";
                }

                if (themeToApply === "dark") {
                    document.documentElement.classList.add("dark");
                } else {
                    document.documentElement.classList.remove("dark");
                }
            };

            applyTheme();
            document.addEventListener("astro:after-swap", applyTheme);
        </script>

        <meta charset="UTF-8" />

        <link rel="dns-prefetch" href={r2Url} />
        <link rel="preconnect" href={r2Url} crossorigin />

        <meta name="viewport" content="width=device-width" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <link rel="icon" href="/favicon.ico" />
        <meta name="generator" content={Astro.generator} />

        <title>EduStack Smart | {title}</title>

        <ClientRouter />

        <meta name="description" content={description} />
        {noindex && <meta name="robots" content="noindex, nofollow" />}
        <link rel="canonical" href={canonical} />

        <meta property="og:title" content={fullTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImage} />
        <meta property="og:url" content={canonical} />
        <meta property="og:type" content="website" />
        <meta property="og:site_name" content="EduStack Smart" />
        <meta property="og:locale" content="es_MX" />

        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:title" content={fullTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImage} />

        {
            jsonLd && (
                <script
                    type="application/ld+json"
                    set:html={JSON.stringify(jsonLd)}
                />
            )
        }

        <link
            rel="icon"
            type="image/svg+xml"
            href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'><rect width='32' height='32' rx='8' fill='%234f46e5'/><text x='16' y='22' font-size='16' font-weight='900' text-anchor='middle' fill='white' font-family='Arial'>ES</text></svg>"
        />

        {
            aiContext && (
                <script
                    id="ai-page-context"
                    type="application/json"
                    set:html={JSON.stringify(aiContext)}
                />
            )
        }
    </head>
    <body class="min-h-screen flex flex-col">
        <Header withSearch={withSearch} />

        <main class="flex-1">
            <BreadcrumbNav items={breadcrumbs} />

            <slot />
        </main>

        <Footer />
    </body>
</html>
